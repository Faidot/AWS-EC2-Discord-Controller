## Part 3 — AWS Lambda Function

The Lambda can live in **any single region** (pick the one closest to you, e.g. `ap-south-1`). It controls instances in **all** regions via boto3 — the function's own region is irrelevant to what it can manage.

### Create Function

1. **Lambda → Create Function**
2. **Name:** `discord-ec2-controller` · **Runtime:** Python 3.12 · **Arch:** x86_64

### Build Deployment Package (AWS CloudShell)

```bash
mkdir discord-bot && cd discord-bot

pip install pynacl \
  --platform manylinux2014_x86_64 \
  --implementation cp --python-version 312 \
  --only-binary=:all: -t .

pip install cffi \
  --platform manylinux2014_x86_64 \
  --implementation cp --python-version 312 \
  --only-binary=:all: -t .
```

Now create the function file:

```bash
cat > lambda_function.py << 'EOF'
import json
import boto3
import os
import nacl.signing
from nacl.exceptions import BadSignatureError
from datetime import datetime, timezone
from collections import defaultdict

# ── Configuration ──────────────────────────────────────────────
DISCORD_PUBLIC_KEY = os.environ['DISCORD_PUBLIC_KEY']
ALLOWED_USER_IDS   = [u.strip() for u in os.environ['ALLOWED_USER_IDS'].split(',') if u.strip()]

# {"gameserver": {"id": "i-0aaa...", "region": "ap-south-1"}, ...}
INSTANCE_MAP = json.loads(os.environ['INSTANCE_MAP'])
ID_TO_NAME   = {v['id']: k for k, v in INSTANCE_MAP.items()}

DISCORD_MSG_LIMIT = 2000

# ── Per-region client cache (created once per warm container) ──
_clients = {}
def ec2_client(region):
    if region not in _clients:
        _clients[region] = boto3.client('ec2', region_name=region)
    return _clients[region]

# On-demand USD/hr (approximate; varies slightly by region)
INSTANCE_COSTS = {
    't2.micro':   0.0116, 't2.small':  0.023,  't2.medium': 0.0464,
    't2.large':   0.0928, 't3.micro':  0.0104, 't3.small':  0.0208,
    't3.medium':  0.0416, 't3.large':  0.0832, 't3.xlarge': 0.1664,
    't3a.micro':  0.0094, 't3a.small': 0.0188, 't3a.medium':0.0376,
    'm5.large':   0.096,  'm5.xlarge': 0.192,  'c5.large':  0.085,
    'c5.xlarge':  0.17,   'r5.large':  0.126,  'r5.xlarge': 0.252,
}
STATE_EMOJI = {'running':'🟢','stopped':'🔴','stopping':'🟡','pending':'🟡',
               'shutting-down':'🟠','terminated':'⚫'}

# ── Security ───────────────────────────────────────────────────
def verify_signature(event):
    try:
        body      = event['body']
        headers   = {k.lower(): v for k, v in event.get('headers', {}).items()}
        timestamp = headers.get('x-signature-timestamp', '')
        signature = headers.get('x-signature-ed25519', '')
        verify_key = nacl.signing.VerifyKey(bytes.fromhex(DISCORD_PUBLIC_KEY))
        verify_key.verify(f"{timestamp}{body}".encode(), bytes.fromhex(signature))
        return True
    except Exception:
        return False

# ── Instance resolution (fool-proof) ───────────────────────────
def resolve_names(name):
    """name string -> (list of instance names, error). Exactly one is None."""
    valid = ", ".join(f"`{n}`" for n in list(INSTANCE_MAP) + ['all'])
    name = (name or '').lower().strip()
    if not name:
        return None, f"❌ No instance specified. Valid: {valid}"
    if name == 'all':
        return list(INSTANCE_MAP), None
    if name not in INSTANCE_MAP:
        return None, f"❌ Unknown instance `{name}`. Valid: {valid}"
    return [name], None

def group_by_region(names):
    """['gameserver','devbox'] -> {'ap-south-1': ['i-0aaa'], 'us-east-1': ['i-0bbb']}"""
    groups = defaultdict(list)
    for n in names:
        info = INSTANCE_MAP[n]
        groups[info['region']].append(info['id'])
    return groups

def pretty(names):
    return ", ".join(f"**{n}**" for n in names)

# ── Actions (one API call per region — fast, bleed-proof) ──────
def do_action(action, names):
    results = []
    for region, ids in group_by_region(names).items():
        try:
            client = ec2_client(region)
            if action == 'start':
                client.start_instances(InstanceIds=ids)
            elif action == 'stop':
                client.stop_instances(InstanceIds=ids)
            elif action == 'reboot':
                client.reboot_instances(InstanceIds=ids)
            results.append(f"✅ {region}: {len(ids)} instance(s) — {action} OK")
        except Exception as e:
            # One region failing must NOT block the others
            results.append(f"⚠️ {region}: FAILED (`{type(e).__name__}`)")
    verb = {'start':'Starting','stop':'Stopping','reboot':'Rebooting'}[action]
    return f"{verb} {pretty(names)}\n" + "\n".join(results)

# ── Status ─────────────────────────────────────────────────────
def build_report(instance, region, compact=False):
    iid   = instance['InstanceId']
    name  = ID_TO_NAME.get(iid, 'unknown')
    state = instance['State']['Name']
    itype = instance.get('InstanceType', 'N/A')
    pub   = instance.get('PublicIpAddress', '—')
    priv  = instance.get('PrivateIpAddress', '—')
    az    = instance.get('Placement', {}).get('AvailabilityZone', region)
    lt    = instance.get('LaunchTime')
    emoji = STATE_EMOJI.get(state, '⚪')

    uptime, session = '—', ''
    if lt and state == 'running':
        diff = datetime.now(timezone.utc) - lt
        hrs  = diff.total_seconds() / 3600
        uptime = f"{int(hrs)}h {int((diff.total_seconds()%3600)//60)}m"
        hourly = INSTANCE_COSTS.get(itype)
        if hourly:
            session = f" | 💸 ${hourly*hrs:.4f}"

    if compact:
        return f"{emoji} **{name}** [{az}] {itype} · {state.upper()} · {pub} · ⏱️{uptime}{session}"

    hourly = INSTANCE_COSTS.get(itype)
    cost = f"~${hourly}/hr | ~${hourly*10:.2f}/day | ~${hourly*10*22:.2f}/mo" if hourly else "N/A"
    return (f"{emoji} **{name}** — EC2 Status\n"
            f"━━━━━━━━━━━━━━━━━━━━\n"
            f"🆔 `{iid}` · 💻 {itype} · 🌍 {az}\n"
            f"📍 **State:** {state.upper()}\n"
            f"🌐 Public: {pub} · 🔒 Private: {priv}\n"
            f"⏱️ Uptime: {uptime}\n"
            f"💰 {cost}{session}\n"
            f"━━━━━━━━━━━━━━━━━━━━")

def get_status(names):
    reports, total = [], 0
    for region, ids in group_by_region(names).items():
        try:
            resp = ec2_client(region).describe_instances(InstanceIds=ids)
            for r in resp['Reservations']:
                for inst in r['Instances']:
                    reports.append((region, inst))
                    total += 1
        except Exception:
            reports.append((region, None))
    compact = total > 2   # fleet view stays under Discord's limit
    out = "\n".join(
        build_report(inst, region, compact) if inst else f"⚠️ {region}: query failed"
        for region, inst in reports
    )
    if len(out) > DISCORD_MSG_LIMIT:
        out = out[:DISCORD_MSG_LIMIT - 20] + "\n…(truncated)"
    return out

# ── Discord plumbing ───────────────────────────────────────────
def respond(message):
    return {'statusCode': 200,
            'headers': {'Content-Type': 'application/json'},
            'body': json.dumps({'type': 4, 'data': {'content': message}})}

def lambda_handler(event, context):
    # ── Path 1: EventBridge Scheduler invocation (direct payload) ──
    if isinstance(event, dict) and event.get('source') == 'scheduler':
        action = event.get('action')          # 'start' | 'stop' | 'reboot'
        names  = event.get('names', [])
        names  = list(INSTANCE_MAP) if names == ['all'] else \
                 [n for n in names if n in INSTANCE_MAP]
        if action in ('start', 'stop', 'reboot') and names:
            result = do_action(action, names)
            print(f"[scheduler] {result}")     # CloudWatch audit trail
            return {'statusCode': 200, 'body': result}
        return {'statusCode': 400, 'body': 'Bad scheduler payload'}

    # ── Path 2: Discord interaction ──
    if not verify_signature(event):
        return {'statusCode': 401, 'body': json.dumps('Invalid signature')}

    body = json.loads(event['body'])

    # Discord PING
    if body.get('type') == 1:
        return {'statusCode': 200, 'body': json.dumps({'type': 1})}

    # Slash command
    if body.get('type') == 2:
        user_id = body.get('member', {}).get('user', {}).get('id') \
                  or body.get('user', {}).get('id', '')
        command = body['data']['name']
        options = body['data'].get('options', [])
        raw = next((o.get('value') for o in options if o.get('name') == 'name'), None)

        if user_id not in ALLOWED_USER_IDS:
            return respond("❌ You are **not authorized**!")

        names, err = resolve_names(raw)
        if err:
            return respond(err)

        try:
            if command == 'start-ec2':
                return respond(do_action('start', names))
            if command == 'stop-ec2':
                return respond(do_action('stop', names))
            if command == 'reboot-ec2':
                return respond(do_action('reboot', names))
            if command == 'status-ec2':
                return respond(get_status(names))
        except Exception as e:
            return respond(f"⚠️ AWS error: `{type(e).__name__}` — check CloudWatch")

        return respond(f"❓ Unknown command `{command}`")

    return {'statusCode': 400, 'body': 'Bad Request'}
EOF

